# Copy this file to `.env` to override docker-compose.yml defaults.
# All values below match the built-in defaults if left unset.
#
# See docs/CONFIGURATION.md for the full environment-variable reference.

# API bearer token. CHANGE THIS for anything beyond local dev.
NOTEDTHAT_API_TOKEN=dev-token-please-change

# Comma-separated KB slugs. Each must match [a-z0-9-]{1,40}.
NOTEDTHAT_KBS=notes,scratch

# S3 region (any value works for SeaweedFS; use the real region for AWS).
NOTEDTHAT_S3_REGION=us-east-1

# S3 credentials (any value works for SeaweedFS; use real creds for AWS/MinIO).
NOTEDTHAT_S3_ACCESS_KEY_ID=any
NOTEDTHAT_S3_SECRET_ACCESS_KEY=any

# Log format: `pretty` (human-readable) or `json` (log aggregators).
NOTEDTHAT_LOG_FORMAT=pretty

# tracing-subscriber filter string.
RUST_LOG=info,notedthat=debug
